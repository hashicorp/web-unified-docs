/**
 * Redirects in this file are intended to be for documentation content only.
 * The redirects will be applied to developer.hashicorp.com.
 */
[
  {
    "source": "/hcp/docs/vagrant",
    "destination": "/vagrant/hcp-docs",
    "permanent": true,
  },
  {
    "source": "/hcp/docs/vagrant/:path*",
    "destination": "/vagrant/hcp-docs/:path*",
    "permanent": true,
  }
]