#!/bin/sh
# Pre-commit hook managed by Husky (primary, for Node users).
# Non-Node contributors: see .githooks/ for the fallback setup.
#
# To opt in to the AI doc reviewer:
#   git config --local doc-review.enabled true

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Run shared base checks (env file guard, defines is_normal_commit_flow)
. "$REPO_ROOT/.husky/pre-commit-base.sh"

# Evaluate once — reused by date metadata and AI reviewer
if is_normal_commit_flow; then
  IS_NORMAL_FLOW=true
else
  IS_NORMAL_FLOW=false
fi

# ── Date metadata (Node required) ─────────────────────────────────────────────
if [ "$IS_NORMAL_FLOW" = "false" ]; then
    echo "Skipping date metadata outside normal commit flow"
else
    MDX_FILES=$(git diff --cached --name-only --diff-filter=d -- content/ | grep '^content/.*\.mdx$' || true)
    if [ -n "$MDX_FILES" ]; then
        echo "Adding date metadata to changed .mdx files..."
        echo "$MDX_FILES" | while read -r FILE; do
            node ./scripts/add-date-metadata.mjs "$FILE" "$(date -Iseconds)"
            git add "$FILE"
        done
    fi
fi

# ── lint-staged (Node required) ───────────────────────────────────────────────
npx lint-staged

# ── AI doc reviewer (opt-in) ──────────────────────────────────────────────────
if [ "$(git config --local doc-review.enabled)" = "true" ]; then
  if [ "$IS_NORMAL_FLOW" = "false" ]; then
    echo "Skipping doc-review outside normal commit flow"
  else
    bash "$REPO_ROOT/.githooks/doc-review.sh"
  fi
fi
