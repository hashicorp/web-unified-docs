#!/bin/sh
# Pre-commit hook — fallback for non-Node contributors.
#
# Husky is the primary pre-commit setup for this repo (see .husky/).
# This hook exists as a backdoor for contributors who do not have Node
# installed and therefore cannot use Husky. Activating this hook disables Husky.
#
# To activate (non-Node users only):
#   git config core.hooksPath .githooks
#
# To opt in to the AI doc reviewer:
#   git config --local doc-review.enabled true
#
# To opt out of the AI doc reviewer:
#   git config --local doc-review.enabled false
#
# To return to Husky:
#   git config core.hooksPath .husky/_

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Run shared base checks (env file guard, defines is_normal_commit_flow)
. "$REPO_ROOT/.husky/pre-commit-base.sh"

# ── AI doc reviewer (opt-in) ──────────────────────────────────────────────────
if [ "$(git config --local doc-review.enabled)" = "true" ]; then
  if ! is_normal_commit_flow; then
    echo "Skipping doc-review outside normal commit flow"
  else
    bash "$REPO_ROOT/.githooks/doc-review.sh"
  fi
fi

